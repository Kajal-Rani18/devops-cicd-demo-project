pipeline {
    agent any

    stages {

        stage('Checkout') {
    steps {
        checkout scm
    }
}
        stage('Verify Node Environment') {
            steps {
                sh '''
                echo "Node Version:"
                node -v

                echo "NPM Version:"
                npm -v
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('Lint') {
            steps {
                sh 'npm run lint'
            }
        }

        stage('Test') {
            steps {
                sh 'npm test'
            }
        }

        stage('Docker Build Image') {
            steps {
                sh 'docker build -t nodeapp .'
            }
        }

        stage('Stop Old Container') {
            steps {
                sh '''
                docker stop nodeapp || true
                docker rm nodeapp || true
                '''
            }
        }

        stage('Deploy Container') {
            steps {
                sh '''
                docker run -d \
                --name nodeapp \
                -p 3000:3000 \
                nodeapp
                '''
            }
        }
    }
}
