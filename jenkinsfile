pipeline {
    agent any

    parameters {

        string(
            name: 'BRANCH_NAME',
            defaultValue: 'version-1.1',
            description: 'Git branch to build'
        )

        choice(
            name: 'DEPLOY_ENV',
            choices: ['Development', 'QA', 'Production'],
            description: 'Select deployment environment'
        )

        booleanParam(
            name: 'SKIP_TESTS',
            defaultValue: false,
            description: 'Skip test stage'
        )

        string(
            name: 'IMAGE_TAG',
            defaultValue: 'latest',
            description: 'Docker image tag to deploy'
        )
    }


    environment {
       IMAGE_NAME = "nodeapp"
     }


    stages {

        stage('Checkout') {
    steps {
        checkout scm
    }
}
        stage('Verify Node Environment') {
            steps {
                sh '''
                echo "Node Version:"
                node -v

                echo "NPM Version:"
                npm -v
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('Lint') {
            steps {
                sh 'npm run lint'
            }
        }

        stage('Test') {
            steps {
                sh 'npm test'
            }
        }

        stage('Docker Build Image') {
            steps {
                sh 'docker build -t ${IMAGE_NAME}:${BUILD_NUMBER} .'
            }
        }

        stage('Stop Old Container') {
            steps {
                sh '''
                docker stop ${IMAGE_NAME} || true
                docker rm ${IMAGE_NAME} || true
                '''
            }
        }

        stage('Deploy Container') {
            steps {
               sh '''
                docker run -d \
                --name ${IMAGE_NAME} \
                -p 3000:3000 \
                ${IMAGE_NAME}:${BUILD_NUMBER}
                '''
            }
        }
    }
} 
